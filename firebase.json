{
   "hosting": {
    "target": "trustydr-app",
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/flutter_service_worker.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/flutter_bootstrap.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/pwa.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "/version.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      }
    ]
  },
    "flutter": {
        "platforms": {
            "android": {
                "default": {
                    "projectId": "doctorapp-7e8b3",
                    "appId": "1:423685278731:android:990247b984742c982e8b0e",
                    "fileOutput": "android/app/google-services.json"
                }
            },
            "ios": {
                "default": {
                    "projectId": "doctorapp-7e8b3",
                    "appId": "1:423685278731:ios:5b69c9a4a5adb0552e8b0e",
                    "uploadDebugSymbols": false,
                    "fileOutput": "ios/Runner/GoogleService-Info.plist"
                }
            },
            "macos": {
                "default": {
                    "projectId": "doctorapp-7e8b3",
                    "appId": "1:423685278731:ios:85917477f8b8c7492e8b0e",
                    "uploadDebugSymbols": false,
                    "fileOutput": "macos/Runner/GoogleService-Info.plist"
                }
            },
            "dart": {
                "lib/firebase_options.dart": {
                    "projectId": "doctorapp-7e8b3",
                    "configurations": {
                        "android": "1:423685278731:android:990247b984742c982e8b0e",
                        "ios": "1:423685278731:ios:5b69c9a4a5adb0552e8b0e",
                        "macos": "1:423685278731:ios:85917477f8b8c7492e8b0e",
                        "web": "1:423685278731:web:767c5e00bb075e532e8b0e",
                        "windows": "1:423685278731:web:ccd90c33645310812e8b0e"
                    }
                }
